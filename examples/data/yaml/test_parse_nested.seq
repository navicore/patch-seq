# Test yaml-parse-nested directly

include std:yaml

: main ( -- Int )
  "Test yaml-parse-nested" io.write-line

  # Test 1: Simple flat parsing
  "host: localhost
port: 8080" yaml-parse-nested

  [
    "Parsed OK: " swap yaml-serialize string.concat io.write-line
  ] [
    drop "Parse failed" io.write-line
  ] if

  0
;
