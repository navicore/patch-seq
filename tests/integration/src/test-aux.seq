# Test: Auxiliary stash stack (>aux / aux>)

# Basic round-trip: value is preserved
: test-basic ( -- )
  42 >aux aux> int->string io.write-line ;

# Multiple values: LIFO preserves original order
# Stack 1 2 3 -> stash all -> restore all -> Stack 1 2 3
: test-lifo ( -- )
  1 2 3
  >aux >aux >aux
  aux> aux> aux>
  # Stack is back to: 1 2 3 (3 on top)
  int->string io.write-line  # prints 3
  int->string io.write-line  # prints 2
  int->string io.write-line  # prints 1
;

# Mixed types on aux
: test-mixed-types ( -- )
  "hello" >aux
  99 >aux
  aux> int->string io.write-line   # prints 99
  aux> io.write-line               # prints hello
;

# Aux inside if/else (balanced in both branches)
: test-if-else ( -- )
  7 >aux
  true [
    aux> 10 i.+ int->string io.write-line
  ] [
    aux> 20 i.+ int->string io.write-line
  ] if ;

# Nested word calls: inner word uses aux independently
: inner-aux ( Int -- Int )
  >aux
  100
  aux> i.+ ;

: test-nested ( -- )
  5 >aux
  10 inner-aux int->string io.write-line  # inner uses its own aux, prints 110
  aux> int->string io.write-line          # outer's aux preserved, prints 5
;

# Aux used alongside normal stack ops
: test-with-stack-ops ( -- )
  1 2 3
  >aux       # stash 3
  swap       # swap 1 and 2: stack is now 2 1
  aux>       # restore 3: stack is now 2 1 3
  int->string io.write-line  # prints 3
  int->string io.write-line  # prints 1
  int->string io.write-line  # prints 2
;

# ============================================================================
# Aux Inside Quotations (Issue #393)
# ============================================================================
# These tests cover the codegen path: each quotation gets its own aux slot
# table, isolated from the enclosing word and from sibling/nested quotations.
# Unlike the print-and-eyeball tests above, these use test.assert-eq so
# `seqc test` actually runs and reports them.

include std:list

# Basic aux round-trip inside a quotation called via `call`.
: test-quotation-aux-round-trip ( -- )
  [ 5 >aux 10 aux> i.+ ] call
  15 test.assert-eq
;

# Nested quotations: each gets its own independent aux slots.
# Outer aux holds 5, inner aux holds 10, neither sees the other.
: test-nested-quotation-aux ( -- )
  [
    5 >aux
    [ 10 >aux 100 aux> i.+ ] call
    aux> i.+
  ] call
  115 test.assert-eq
;

# Aux inside a `list.each` callback. The fold body uses aux for temporary
# storage. We assert by accumulating the printed values' sum into a fold.
: test-aux-in-list-each-via-fold ( -- )
  # Use list.fold (which has a verifiable result) to exercise aux in a
  # combinator quotation. For each element, stash it, multiply acc by 2,
  # then add the stashed element back. With elements [1,2,3,4] and acc=0:
  # 0 -> 1 -> 4 -> 11 -> 26
  list-of 1 lv 2 lv 3 lv 4 lv
  0 [ >aux 2 i.* aux> i.+ ] list.fold
  26 test.assert-eq
;

# Closure that uses aux internally. The closure captures one Int and
# takes one Int input; the body uses aux for temporary storage.
: aux-using-closure ( Int -- Closure[Int -- Int] )
  # Body sees ( captured_base input ); stash input, increment base, restore.
  [ >aux 1 i.+ aux> i.+ ]
;

: test-aux-in-closure ( -- )
  # 10 captured, 5 input: stash 5, 10+1=11, restore 5, 11+5=16
  10 aux-using-closure 5 swap call
  16 test.assert-eq
;
