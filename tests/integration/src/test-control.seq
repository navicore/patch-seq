# Integration tests for `if`, `when`, `unless`.
#
# `if` is the conditional combinator (Seq 6.0). `when` / `unless` are
# stdlib combinators built on top of it.

include std:control

# --------------------------------------------------------------------------
# if ( ..a Bool [..a -- ..b] [..a -- ..b] -- ..b )
# --------------------------------------------------------------------------

: test-if-combinator-true ( -- )
  # True selects the first quotation (then-branch).
  true [ 1 ] [ 2 ] if
  1 test.assert-eq
;

: test-if-combinator-false ( -- )
  # False selects the second quotation (else-branch).
  false [ 1 ] [ 2 ] if
  2 test.assert-eq
;

: test-if-combinator-consumes-stack ( -- )
  # Both quotations may consume from below themselves.
  10 5 true  [ i.+ ] [ i.- ] if
  15 test.assert-eq

  10 5 false [ i.+ ] [ i.- ] if
  5 test.assert-eq
;

: test-if-combinator-empty-quotation ( -- )
  # Empty quotation is the natural no-op for unchanged stack shape.
  42 true  [ ] [ drop 99 ] if
  42 test.assert-eq

  42 false [ ] [ drop 99 ] if
  99 test.assert-eq
;

: test-if-combinator-from-comparison ( -- )
  # The Bool can come from any boolean-producing expression.
  5 3 i.> [ "yes" ] [ "no" ] if
  "yes" test.assert-eq-str

  3 5 i.> [ "yes" ] [ "no" ] if
  "no" test.assert-eq-str
;

# --------------------------------------------------------------------------
# when ( ..a Bool [ ..a -- ..a ] -- ..a )
# --------------------------------------------------------------------------

: test-when-true-fires ( -- )
  0 true [ drop 1 ] when
  1 test.assert-eq
;

: test-when-false-skips ( -- )
  0 false [ drop 1 ] when
  0 test.assert-eq
;

: test-when-preserves-stack ( -- )
  # When the quotation is a no-op (preserves shape), `when` is a no-op
  # whether the condition is true or false.
  42 true  [ ] when
  42 test.assert-eq

  42 false [ ] when
  42 test.assert-eq
;

: test-when-transforms-value ( -- )
  # ( Int -- Int ) quotation, applied conditionally
  5 dup 0 i.> [ 1 i.+ ] when
  6 test.assert-eq

  -3 dup 0 i.> [ 1 i.+ ] when
  -3 test.assert-eq
;

# --------------------------------------------------------------------------
# unless ( ..a Bool [ ..a -- ..a ] -- ..a )
# --------------------------------------------------------------------------

: test-unless-false-fires ( -- )
  0 false [ drop 1 ] unless
  1 test.assert-eq
;

: test-unless-true-skips ( -- )
  0 true [ drop 1 ] unless
  0 test.assert-eq
;

: test-unless-mirror-of-when ( -- )
  # `unless` is `when` with the condition negated.
  10 false [ 5 i.+ ] unless
  15 test.assert-eq

  10 true [ 5 i.+ ] unless
  10 test.assert-eq
;

# --------------------------------------------------------------------------
# Dynamic dispatch path
# --------------------------------------------------------------------------
# When the two quotations passed to `if` are NOT literal `[ ... ]` at
# the call site (e.g. they come in as word arguments or are stored in
# variables), the AST-level inlining is bypassed and the runtime
# `patch_seq_if` dispatch handles it. This test guards the fallback path.

: pick-via-arg ( Bool [ -- Int ] [ -- Int ] -- Int )
  if
;

: const-7  ( -- Int ) 7 ;
: const-13 ( -- Int ) 13 ;

: test-if-dynamic-dispatch ( -- )
  true  [ const-7 ] [ const-13 ] pick-via-arg
  7 test.assert-eq

  false [ const-7 ] [ const-13 ] pick-via-arg
  13 test.assert-eq
;

# --------------------------------------------------------------------------
# Yield-bearing branches
# --------------------------------------------------------------------------
# `if` accepts branches whose bodies yield (e.g. `chan.send` /
# `chan.receive`). This matches the keyword form's behaviour and
# protects the literal-quotation lowering path from regressing into
# dip/keep/bi's stricter "no Yield in branches" rule.

: test-if-yield-branch ( -- )
  # Confirm an `if` branch can contain a yielding operation. The
  # literal-quotation triple is lowered to `Statement::If`, which
  # accepts Yield-bearing branches — matching the keyword form's
  # behaviour and unlike `dip`/`keep`/`bi` which reject Yield.
  # `chan.yield` is the cooperative scheduler yield, no channel
  # state needed.
  true  [ chan.yield 1 ] [ chan.yield 2 ] if
  1 test.assert-eq

  false [ chan.yield 1 ] [ chan.yield 2 ] if
  2 test.assert-eq
;
