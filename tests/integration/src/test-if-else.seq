# Test if/else/then conditionals

: test-if-else-true ( -- )
  # When condition is true, true branch executes
  5 3 i.>
  [
    1
  ] [
    0
  ] if
  1 test.assert-eq
;

: test-if-else-false ( -- )
  # When condition is false, else branch executes
  3 5 i.>
  [
    1
  ] [
    0
  ] if
  0 test.assert-eq
;

: test-equality ( -- )
  5 5 i.= test.assert
  5 3 i.= test.assert-not
;
